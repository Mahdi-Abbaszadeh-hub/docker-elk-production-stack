# ELK Stack Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains real credentials.
# This file (.env.example) is safe to commit.

# Version of the ELK stack (all three services use the same version)
STACK_VERSION=8.12.0

# Password for the built-in Elasticsearch 'elastic' superuser
# Use a strong password — min 8 characters, mix of letters/numbers/symbols
ELASTIC_PASSWORD=change_me_before_running

# Memory limit for the Elasticsearch container
# Rule of thumb: set to ~2x your ES_JAVA_OPTS heap size
# Example: if heap is 512m, set this to 1g
ES_MEM_LIMIT=1g